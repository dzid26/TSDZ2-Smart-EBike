{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "SDCC build",
			"command": "make",
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			},
			"args": [
				"all"
			],
			"options": {
				"cwd": "${workspaceFolder}/src/"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "process",
			"label": "STM8 Flash",
			"windows": {
			  "command": "flash.bat"
			},
			"osx": { //untested
				"command": "make flash",
			},
			"linux": { //untested
				"command": "make flash",
			},
			"options": {
				"cwd": "${workspaceFolder}/src"
			},
			"dependsOn": [
				"SDCC build"
			],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"close": true
			},
			"problemMatcher": []
		},
		{
			"label": "Launch OpenOCD",
			"type": "shell",
			"command": "openocd",
			"args": [
				"-f",
				"interface/stlink-dap.cfg",  //swim is @stlink-dap in openocd > 10.0
				"-f",
				"target/stm8s105.cfg"
			],
			"problemMatcher": [],
		},
		{
			"label": "Flash with OpenOCD",
			"type": "process",
			"presentation": {
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": true,
				"clear": false
			},
			"dependsOn": "SDCC build",
			"command": "openocd",
			"options": {
				"cwd": "${workspaceFolder}",
			},
			"runOptions": {
				"instanceLimit": 1,
			},
			"args": [
				"-d2",
				"-f",
				"interface/stlink-dap.cfg",
				"-f",
				"target/stm8s105.cfg",
				"-c",
				"init",
				"-c",
				"reset halt",
                "-c",
                "load_image bin/main.hex 0x8000",
				"-c",
				"exit",
                // "-c",
                // "program orig.hex",
			],
			"problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
		}
	],
}